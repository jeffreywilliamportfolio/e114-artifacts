# Git LFS — large/binary durable artifacts. Text (md/py/tex/sh/tsv/small json) stays in normal git.
# Note: with these runs, no single file exceeds GitHub's 100 MB hard limit; LFS is used to keep
# clones lean and avoid bloating .git history with multi-MB result blobs.
*.csv  filter=lfs diff=lfs merge=lfs -text
*.png  filter=lfs diff=lfs merge=lfs -text
*.pdf  filter=lfs diff=lfs merge=lfs -text
*.json filter=lfs diff=lfs merge=lfs -text
.zenodo.json -filter -diff -merge text
paper/*.pdf -filter -diff -merge -text
paper/figs/*.pdf -filter -diff -merge -text
runs/35b/qwen3.5-35b-a3b-114-autointerp/results/*.json -filter -diff -merge text
runs/35b/qwen3.5-35b-a3b-huahua-114-causal-gate-bias/raw/*.json -filter -diff -merge text
runs/35b/qwen3.5-35b-a3b-huahua-114-causal-gate-bias/results/*.json -filter -diff -merge text
runs/35b/qwen3.5-35b-a3b-huahua-114-causal-gate-bias/results/rating_batches/*.json -filter -diff -merge text
